{
  "name": "penut-operator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Local AI browser operator for approved Penut tasks.",
  "author": "Penut",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron .",
    "dev:local": "PENUT_OPERATOR_CHANNEL=local ELECTRON_RUN_AS_NODE= electron .",
    "dev:dev": "PENUT_OPERATOR_CHANNEL=dev ELECTRON_RUN_AS_NODE= electron .",
    "dev:prod": "PENUT_OPERATOR_CHANNEL=prod ELECTRON_RUN_AS_NODE= electron .",
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:mac:arm64": "electron-builder --mac --arm64",
    "dist:mac:x64": "electron-builder --mac --x64",
    "dist:win": "electron-builder --win",
    "dist:win:x64": "electron-builder --win --x64",
    "pack": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:runtime": "node scripts/build-python-runtime.mjs",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "smoke:startup": "node scripts/smoke-startup.mjs",
    "verify": "npm run check && npm run smoke:startup && npm run agent:dry-run",
    "agent:dry-run": "node src/agent/cli.js --dry-run",
    "check": "node --check src/main/main.js && node --check src/main/preload.cjs && node --check src/renderer/renderer.js && node --check src/config/environment.js && node --check src/penut/penut-api-client.js && node --check src/agent/ai/openai-client.js && node --check src/agent/ai/action-planner.js && node --check src/agent/browser-actions.js && node --check src/agent/cli.js && node --check src/agent/runtime.js && node --check src/browser/chrome-controller.js && node --check src/storage/task-store.js && node --check src/storage/settings-store.js && node --check src/storage/auth-store.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ai.penut.operator",
    "productName": "Penut Operator",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "build/python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "scripts/notarize.mjs",
    "dmg": {
      "sign": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://penut.ai/operator/updates"
      }
    ]
  }
}
